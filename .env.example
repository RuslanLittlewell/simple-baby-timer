# Supabase project credentials (Dashboard → Settings → API Keys).
# Copy to .env and fill in — Expo inlines EXPO_PUBLIC_* at build time.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY

# Never prefix secret keys with EXPO_PUBLIC_ — they must not reach the app.
# SUPABASE_SECRET_KEY=sb_secret_...
